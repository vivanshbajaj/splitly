# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/splitly?retryWrites=true&w=majority

# JWT Secret — can be ANY random string (e.g. "mySuperSecretKey123")
JWT_SECRET=your_random_secret_key_here

# Port for the backend server
PORT=5000
